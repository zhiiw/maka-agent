{
  "name": "@maka/headless",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ahe-target-protocol": {
      "types": "./dist/ahe-target-protocol.d.ts",
      "default": "./dist/ahe-target-protocol.js"
    },
    "./ahe-evidence-export": {
      "types": "./dist/ahe-evidence-export.d.ts",
      "default": "./dist/ahe-evidence-export.js"
    },
    "./eval-router": {
      "types": "./dist/eval-router.d.ts",
      "default": "./dist/eval-router.js"
    }
  },
  "imports": {
    "#fixed-prompt-task-source": "./dist/fixed-prompt-task-source.js",
    "#headless-run-env": "./dist/headless-run-env.js",
    "#prompt-optimization-env": "./dist/prompt-optimization-env.js",
    "#prompt-optimization-bootstrap": "./dist/prompt-optimization-bootstrap.js",
    "#prompt-optimization-manifest": "./dist/prompt-optimization-manifest.js",
    "#prompt-optimization-profile": "./dist/prompt-optimization-profile.js",
    "#prompt-control-run": "./dist/prompt-control-run.js",
    "#prompt-optimization-run": "./dist/prompt-optimization-run.js",
    "#ab-manifest": "./dist/ab-manifest.js",
    "#prompt-ab-run": "./dist/prompt-ab-run.js",
    "#harbor-task-runner": "./dist/harbor-task-runner.js",
    "#harbor-smoke-config": "./dist/harbor-smoke-config.js",
    "#provider-env": "./dist/provider-env.js",
    "#harbor-cell": "./dist/harbor-cell.js",
    "#opencode-toolchain": "./dist/opencode-toolchain.js",
    "#kimi-code-toolchain": "./dist/kimi-code-toolchain.js",
    "#runtime-policy-ab-profile": "./dist/runtime-policy-ab-profile.js",
    "#runtime-policy-ab-spec": "./dist/runtime-policy-ab-spec.js",
    "#runtime-policy-ab-run": "./dist/runtime-policy-ab-run.js",
    "#runtime-policy-ab-lifecycle": "./dist/runtime-policy-ab-lifecycle.js",
    "#harness-ab-manifest": "./dist/harness-ab-manifest.js",
    "#harness-oracle-registry": "./dist/harness-oracle-registry.js",
    "#harness-oracle-policy": "./dist/harness-oracle-policy.js",
    "#harness-ab-run": "./dist/harness-ab-run.js",
    "#harness-ab-report": "./dist/harness-ab-report.js",
    "#prompt-structural-smoke": "./dist/prompt-structural-smoke.js"
  },
  "bin": {
    "maka-headless": "./dist/cli.js"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-paths.mjs dist tsconfig.tsbuildinfo",
    "build": "tsc -p tsconfig.json && node scripts/chmod-bin.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run clean && npm run build && npm run test:dist",
    "test:dist": "node ../../scripts/run-headless-tests.mjs"
  },
  "dependencies": {
    "@maka/core": "0.1.0",
    "@maka/runtime": "0.1.0",
    "@maka/storage": "0.1.0",
    "ai": "^7.0.31"
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "{env:ZAI_API_KEY}",
        "baseURL": "{env:ZAI_BASE_URL}"
      }
    },
    "kimi-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "Kimi Coding Plan",
      "options": {
        "apiKey": "{env:KIMI_API_KEY}",
        "baseURL": "{env:KIMI_BASE_URL}"
      },
      "models": {
        "k3": {
          "name": "Kimi K3",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "options": {
            "thinking": {
              "type": "adaptive"
            },
            "effort": "max"
          },
          "variants": {
            "max": {
              "thinking": {
                "type": "adaptive"
              },
              "effort": "max"
            }
          }
        }
      }
    }
  }
}
